  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK385">
<l>iyaṟṟalu mīṭṭaluṅ kāttaluṅ kātta</l>
<l>vakuttalum valla taracu</l>            
            </lg>
            <lg xml:lang="en">
<l>He is a king who is able to acquire (wealth), to lay it up, to guard, and to distribute it.</l>
            </lg>
        </div>
