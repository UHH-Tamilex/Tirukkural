  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK702">
<l>aiyap paṭāa takatta tuṇarvārait</l>
<l>teyvattō ṭoppak koḷal</l>            
            </lg>
            <lg xml:lang="en">
<l>He is to be esteemed a god who is able to ascertain without a doubt what is within (one's mind).</l>
            </lg>
        </div>
