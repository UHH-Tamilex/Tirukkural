  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK227">
<l>pāttūṇ marīi yavaṉaip paciyeṉṉun</l>
<l>tīppiṇi tīṇṭa laritu</l>            
            </lg>
            <lg xml:lang="en">
<l>The fiery disease of hunger shall never touch him who habitually distributes his food to others.</l>
            </lg>
        </div>
