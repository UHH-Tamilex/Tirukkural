  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK692">
<l>maṉṉar viḻaipa viḻaiyāmai maṉṉarāṉ </l>
<l>maṉṉiya vākkan tarum</l>            
            </lg>
            <lg xml:lang="en">
<l>For ministers not to cover the things desired by their kings will through the kings themselves yield them everlasting wealth.</l>
            </lg>
        </div>
