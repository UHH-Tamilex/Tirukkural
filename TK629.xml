  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK629">
<l>iṉpattu ḷiṉpamviḻaiyātāṉ ṟuṉpattuṭ</l>
<l> ṭuṉpa muṟuta lilaṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>He does not suffer sorrow, in sorrow who does not look for pleasure in pleasure.</l>
            </lg>
        </div>
    </body>
