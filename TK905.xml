  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK905">
<l>illāḷai yañcuvā ṉañcumaṟ ṟeññāṉṟu </l>
<l> nallārkku nalla ceyal</l>            
            </lg>
            <lg xml:lang="en">
<l>He that fears his wife will always be afraid of doing good deeds (even) to the good.</l>
            </lg>
