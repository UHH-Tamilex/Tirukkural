  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK524">
<l>cuṟṟattāṟ cuṟṟap paṭavoḻukal celvantāṉ </l>
<l> peṟṟattāṟ peṟṟa payaṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>To live surrounded by relatives, is the advantage to be derived from the acquisition of wealth.</l>
            </lg>
        </div>
