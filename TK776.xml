  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK776">
<l>viḻuppuṇ paṭātanā ḷellām vaḻukkiṉuḷ</l>
<l>vaikkuntaṉ ṉāḷai yeṭuttu</l>            
            </lg>
            <lg xml:lang="en">
<l>The hero will reckon among wasted days all those on which he had not received severe wounds.</l>
            </lg>
        </div>
