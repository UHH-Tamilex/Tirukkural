  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK923">
<l>īṉṟāḷ mukattēyu miṉṉātā leṉmaṟṟuc </l>
<l>cāṉṟōr mukattuk kaḷi</l>            
            </lg>
            <lg xml:lang="en">
<l>Intoxication is painful even in the presence of (one's) mother; what will it not then be in that of the wise ?</l>
            </lg>
        </div>
    </body>
