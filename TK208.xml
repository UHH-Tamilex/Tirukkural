  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK208">
<l>tīyavai ceytār keṭuta ṉiḻaṟaṉṉai</l>
<l>vīyā taṭiyuṟain taṟṟu</l>            
            </lg>
            <lg xml:lang="en">
<l>Destruction will dwell at the heels of those who commit evil even as their shadow that leaves them not.</l>
            </lg>
        </div>
