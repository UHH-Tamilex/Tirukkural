  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK372">
<l>pētaip paṭukku miḻavū ḻaṟivakaṟṟu</l>
<l>mākalū ḻuṟṟak kaṭai</l>            
            </lg>
            <lg xml:lang="en">
<l>An adverse fate produces folly, and a prosperous fate produces enlarged knowledge.</l>
            </lg>
        </div>
