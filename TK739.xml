  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK739">
<l>nāṭeṉpa nāṭā vaḷattaṉa nāṭalla</l>
<l>nāṭa vaḷantaru nāṭu</l>            
            </lg>
            <lg xml:lang="en">
<l>The learned say that those are kingdom whose wealth is not laboured for, and those not, whose wealth is only obtained through labour.</l>
            </lg>
        </div>
