  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK386">
<l>kāṭcik keḷiyaṉ kaṭuñcolla ṉallaṉēl</l>
<l>mīkkūṟu maṉṉa ṉilam</l>            
            </lg>
            <lg xml:lang="en">
<l>The whole world will exalt the country of the king who is easy of access, and who is free from harsh language.</l>
            </lg>
        </div>
