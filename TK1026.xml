  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK1026">
<l>nallāṇmai yeṉpa toruvaṟkut tāṉpiṟanta</l>
<l>villāṇmai yākkik koḷal</l>            
            </lg>
            <lg xml:lang="en">
<l>A man's true manliness consists in making himself the head and benefactor of his family.</l>
            </lg>
