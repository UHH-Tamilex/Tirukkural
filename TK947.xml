  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK947">
<l>tīyaḷa vaṉṟit teriyāṉ perituṇṇi </l>
<l>ṉōyaḷa viṉṟip paṭum</l>            
            </lg>
            <lg xml:lang="en">
<l>He will be afflicted with numberless diseases, who eats immoderately, ignorant (of the rules of health).</l>
            </lg>
        </div>
