  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK260">
<l>kollāṉ pulālai maṟuttāṉaik kaikūppi</l>
<l>yellā vuyirun toḻum</l>            
            </lg>
            <lg xml:lang="en">
<l>All creatures will join their hands together, and worship him who has never taken away life, nor eaten flesh.</l>
            </lg>
