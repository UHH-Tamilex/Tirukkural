  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK877">
<l>nōvaṟka nonta taṟiyārkku mēvaṟka </l>
<l>meṉmai pakaiva rakattu</l>            
            </lg>
            <lg xml:lang="en">
<l>Relate not your suffering even to friends who are ignorant of it, nor refer to your weakness in the presence of your foes.</l>
            </lg>
        </div>
