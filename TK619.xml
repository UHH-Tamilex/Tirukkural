  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK619">
<l>teyvattā ṉākā teṉiṉu muyaṟcitaṉ </l>
<l>meyvaruttak kūli tarum</l>            
            </lg>
            <lg xml:lang="en">
<l>Although it be said that, through fate, it cannot be attained, yet labour, with bodily exertion, will yield its reward.</l>
            </lg>
        </div>
