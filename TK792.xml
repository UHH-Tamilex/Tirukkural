  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK792">
<l>āyntāyntu koḷḷātāṉ kēṇmai kaṭaimuṟai</l>
<l>tāṉcān tuyaran tarum</l>            
            </lg>
            <lg xml:lang="en">
<l>The friendship contracted by him who has not made repeated inquiry will in the end grieve (him) to death.</l>
            </lg>
        </div>
