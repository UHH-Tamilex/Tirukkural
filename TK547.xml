  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK547">
<l>iṟaikākkum vaiyaka mellā mavaṉai </l>
<l>muṟaikākku muṭṭāc ceyiṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>The king defends the whole world; and justice, when administered without defect, defends the king.</l>
            </lg>
        </div>
