  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK911">
<l>aṉpiṉ viḻaiyār poruḷviḻaiyu māytoṭiyā </l>
<l>riṉco liḻukkan tarum</l>            
            </lg>
            <lg xml:lang="en">
<l>The sweet words of elegant braceleted (prostitutes) who desire (a man) not from affection but from avarice, will cause sorrow.</l>
            </lg>
        </div>
    </body>
