  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK192">
<l>payaṉila pallārmuṟ colla ṉayaṉila</l>
<l>naṭṭārkaṭ ceytaliṟ ṟītu</l>            
            </lg>
            <lg xml:lang="en">
<l>To speak useless things in the presence of many is a greater evil than to do unkind things towards friends.</l>
            </lg>
        </div>
