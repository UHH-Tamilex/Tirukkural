  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK824">
<l>mukatti ṉiṉiya nakāa vakattiṉṉā</l>
<l>vañcarai yañcap paṭum</l>            
            </lg>
            <lg xml:lang="en">
<l>One should fear the deceitful who smile sweetly with their face but never love with their heart.</l>
            </lg>
        </div>
    </body>
