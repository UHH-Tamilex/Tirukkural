  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK1002">
<l>poruḷāṉā mellāmeṉ ṟīyā tivaṟu</l>
<l>maruḷāṉā māṇāp piṟappu</l>            
            </lg>
            <lg xml:lang="en">
<l>He who knows that wealth yields every pleasure and yet is so blind as to lead miserly life will be born a demon.</l>
            </lg>
        </div>
    </body>
