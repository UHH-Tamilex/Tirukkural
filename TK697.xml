  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK697">
<l>vēṭpaṉa colli viṉaiyila veññāṉṟuṅ </l>
<l>kēṭpiṉuñ collā viṭal</l>            
            </lg>
            <lg xml:lang="en">
<l>Ministers should (always) give agreeable advice but on no occasion recommend useless actions, though requested (to do so).</l>
            </lg>
        </div>
    </body>
