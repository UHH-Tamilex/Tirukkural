  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK444">
<l>tammiṟ periyār tamarā voḻukutal</l>
<l>vaṉmaiyu ḷellān talai</l>            
            </lg>
            <lg xml:lang="en">
<l>So to act as to make those men, his own, who are greater than himself is of all powers the highest.</l>
            </lg>
        </div>
    </body>
