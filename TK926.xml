  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK926">
<l>tuñciṉār cettāriṉ vēṟalla reññāṉṟu</l>
<l> nañcuṇpār kaḷḷuṇ pavar.</l>            
            </lg>
            <lg xml:lang="en">
<l>They that sleep resemble the deed (likewise) they that drink are no other than poison-eaters.</l>
            </lg>
        </div>
    </body>
