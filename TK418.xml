  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK418">
<l>kēṭpiṉuṅ kēḷāt takaiyavē kēḷviyāṟ</l>
<l>ṟōṭkap paṭāta cevi</l>            
            </lg>
            <lg xml:lang="en">
<l>The ear which has not been bored by instruction, although it hears, is deaf.</l>
            </lg>
        </div>
    </body>
