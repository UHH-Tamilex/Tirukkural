  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK864">
<l>nīṅkāṉ vekuḷi niṟaiyila ṉeññāṉṟum </l>
<l>yāṅkaṇum yārkku meḷitu</l>            
            </lg>
            <lg xml:lang="en">
<l>He who neither refrains from anger nor keeps his secrets will at all times and in all places be easily conquered by all.</l>
            </lg>
        </div>
    </body>
  </text>
