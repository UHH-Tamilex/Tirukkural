  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK316">
<l>iṉṉā veṉattā ṉuṇarntavai tuṉṉāmai</l>
<l>vēṇṭum piṟaṉkaṭ ceyal</l>            
            </lg>
            <lg xml:lang="en">
<l>Let not a man consent to do those things to another which, he knows, will cause sorrow.</l>
            </lg>
        </div>
    </body>
