  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK748">
<l>muṟṟāṟṟi muṟṟi yavaraiyum paṟṟāṟṟip</l>
<l>paṟṟiyār velva taraṇ</l>            
            </lg>
            <lg xml:lang="en">
<l>That is a fort whose inmates are able to overcome without losing their ground, even abler men who have besieged it.</l>
            </lg>
        </div>
    </body>
