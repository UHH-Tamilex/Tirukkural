  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK816">
<l>pētai peruṅkeḻīi naṭpi ṉaṟivuṭaiyā </l>
<l>rētiṉmai kōṭi yuṟum</l>            
            </lg>
            <lg xml:lang="en">
<l>The hatred of the wise is ten-million times more profitable than the excessive intimacy of the fool.</l>
            </lg>
        </div>
    </body>
