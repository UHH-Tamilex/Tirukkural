  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK233">
<l>oṉṟā vulakat tuyarnta pukaḻallāṟ</l>
<l>poṉṟātu niṟpatoṉ ṟil</l>            
            </lg>
            <lg xml:lang="en">
<l>There is nothing that stands forth in the world imperishable, except fame, exalted in solitary greatness.</l>
            </lg>
        </div>
