  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK1049">
<l>neruppiṉuṭ ṭuñcalu māku nirappiṉuḷ</l>
<l>yātoṉṟuṅ kaṇpā ṭaritu</l>            
            </lg>
            <lg xml:lang="en">
<l>One may sleep in the midst of fire but by no means in the midst of poverty.</l>
            </lg>
