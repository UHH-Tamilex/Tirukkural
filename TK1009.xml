  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK1009">
<l>aṉporīit taṟceṟ ṟaṟanōkkā tīṭṭiya </l>
<l>voṇporuḷ koḷvār piṟar</l>            
            </lg>
            <lg xml:lang="en">
<l>Strangers will inherit the riches that have been acquired without regard for friendship, comfort and charity.</l>
            </lg>
