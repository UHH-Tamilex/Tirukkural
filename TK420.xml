  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK420">
<l>ceviyiṟ cuvaiyuṇarā vāyuṇarviṉ mākka</l>
<l>ḷaviyiṉum vāḻiṉu meṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>What does it matter whether those men live or die, who can judge of tastes by the mouth, and not by the ear ?</l>
            </lg>
        </div>
