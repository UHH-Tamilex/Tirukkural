  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK363">
<l>vēṇṭāmai yaṉṉa viḻuccelva mīṇṭillai </l>
<l>yāṇṭu maḵtoppa til</l>            
            </lg>
            <lg xml:lang="en">
<l>There is in this world no excellence equal to freedom from desire; and even in that world, there is nothing like it.</l>
            </lg>
        </div>
    </body>
