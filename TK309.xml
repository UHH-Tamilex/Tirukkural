  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK309">
<l>uḷḷiya vellā muṭaṉeytu muḷḷattā</l>
<l>ṉuḷḷāṉ vekuḷi eṉiṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>If a man never indulges anger in his heart, he will at once obtain whatever he has thought of.</l>
            </lg>
        </div>
    </body>
  </text>
