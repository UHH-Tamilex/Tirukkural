  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK164">
<l>aḻukkāṟṟi ṉallavai ceyyā riḻukkāṟṟi</l>
<l>ṉētam paṭupāk kaṟintu</l>            
            </lg>
            <lg xml:lang="en">
<l>(The wise) knowing the misery that comes from transgression will not through envy commit unrighteous deeds.</l>
            </lg>
        </div>
    </body>
