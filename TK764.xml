  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK764">
<l>aḻiviṉ ṟaṟaipōkā tāki vaḻivanta</l>
<l>vaṉka ṇatuvē paṭai</l>            
            </lg>
            <lg xml:lang="en">
<l>That indeed is an army which has stood firm of old without suffering destruction or deserting (to the enemy).</l>
            </lg>
        </div>
    </body>
