  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK540">
<l>uḷḷiya teyta leḷitumaṉ maṟṟuntā </l>
<l>ṉuḷḷiya tuḷḷap peṟiṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>It is easy for (one) to obtain whatever he may think of, if he can again think of it.</l>
            </lg>
        </div>
