  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK336">
<l>neruna luḷaṉoruva ṉiṉṟillai yeṉṉum</l>
<l>perumai yuṭaittiv vulaku</l>            
            </lg>
            <lg xml:lang="en">
<l>This world possesses the greatness that one who yesterday was is not today.</l>
            </lg>
