  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK161">
<l>oḻukkāṟāk koḷka voruvaṉṟaṉ ṉeñcat</l>
<l>taḻukkā ṟilāta viyalpu</l>            
            </lg>
            <lg xml:lang="en">
<l>Let a man esteem that disposition which is free from envy in the same manner as propriety of conduct.</l>
            </lg>
        </div>
    </body>
