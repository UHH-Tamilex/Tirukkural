  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK271">
<l>vañca maṉattāṉ paṭiṟṟoḻukkam pūtaṅka</l>
<l>ḷaintu makattē nakum</l>            
            </lg>
            <lg xml:lang="en">
<l>The five elements (of his body) will laugh within him at the feigned conduct of the deceitful minded man.</l>
            </lg>
        </div>
