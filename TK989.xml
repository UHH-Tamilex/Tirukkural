  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK989">
<l>ūḻi peyariṉun tāmpeyarār cāṉṟāṇmaik</l>
<l>kāḻi yeṉappaṭu vār</l>            
            </lg>
            <lg xml:lang="en">
<l>Those who are said to be the shore of the sea of perfection will never change, though ages may change.</l>
            </lg>
