  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK319">
<l>piṟarkkiṉṉā muṟpakaṟ ceyyiṟ tamakkiṉṉā</l>
<l>piṟpakaṟ ṟāmē varum</l>            
            </lg>
            <lg xml:lang="en">
<l>If a man inflict sorrow upon others in the morning, it will come upon him unsought in the very evening.</l>
            </lg>
        </div>
