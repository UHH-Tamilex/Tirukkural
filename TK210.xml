  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK210">
<l>aruṅkēṭa ṉeṉpa taṟika maruṅkōṭit</l>
<l>tīviṉai ceyyā ṉeṉiṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>Know ye that he is freed from destruction who commits no evil, going to neither side of the right path.</l>
            </lg>
        </div>
    </body>
