  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK1047">
<l>aṟañcārā nalkura vīṉṟatā yāṉum </l>
<l>piṟaṉpōla nōkkap paṭum</l>            
            </lg>
            <lg xml:lang="en">
<l>He that is reduced to absolute poverty will be regarded as a stranger even by his own mother.</l>
            </lg>
