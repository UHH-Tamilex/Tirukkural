  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK439">
<l>viyavaṟka veññāṉṟun taṉṉai nayavaṟka</l>
<l>naṉṟi payavā viṉai</l>            
            </lg>
            <lg xml:lang="en">
<l>Let no (one) praise himself, at any time; let him not desire to do useless things.</l>
            </lg>
        </div>
    </body>
