  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK972">
<l>piṟappokku mellā vuyirkkuñ ciṟappovvā </l>
<l>ceytoḻil vēṟṟumai yāṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>All human beings agree as regards their birth but differ as regards their characteristics, because of the different qualities of their actions.</l>
            </lg>
        </div>
