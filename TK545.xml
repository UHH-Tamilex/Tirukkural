  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK545">
<l>iyalpuḷik kōlōccu maṉṉava ṉāṭṭa </l>
<l>peyalum viḷaiyuḷun tokku</l>            
            </lg>
            <lg xml:lang="en">
<l>Rain and plentiful crops will ever dwell together in the country of the king who sways his sceptre with justice.</l>
            </lg>
        </div>
