  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK240">
<l>vacaiyoḻiya vāḻvārē vāḻvā ricaiyoḻiya</l>
<l>vāḻvārē vāḻā tavar</l>            
            </lg>
            <lg xml:lang="en">
<l>Those live who live without disgrace. Those who live without fame live not.</l>
            </lg>
        </div>
