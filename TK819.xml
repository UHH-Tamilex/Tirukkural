  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK819">
<l>kaṉaviṉu miṉṉātu maṉṉō viṉaivēṟu </l>
<l>colvēṟu paṭṭār toṭarpu</l>            
            </lg>
            <lg xml:lang="en">
<l>The friendship of those whose actions do not agree with their words will distress (one) even in (one's) dreams.</l>
            </lg>
        </div>
    </body>
