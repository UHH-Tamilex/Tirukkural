  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK938">
<l>poruḷkoṭuttup poymēṟ koḷīi yaruḷkeṭuttu</l>
<l>alla luḻappikkuñ cūtu</l>            
            </lg>
            <lg xml:lang="en">
<l>Gambling destroys property, teaches falsehood, puts an end to benevolence, and brings in misery (here and hereafter).</l>
            </lg>
        </div>
    </body>
