  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK413">
<l>ceviyuṇaviṟ kēḷvi yuṭaiyā raviyuṇavi</l>
<l>ṉāṉṟārō ṭoppar nilattu</l>            
            </lg>
            <lg xml:lang="en">
<l>Those who in this world enjoy instruction which is the food of the ear, are equal to the Gods, who enjoy the food of the sacrifices.</l>
            </lg>
        </div>
    </body>
