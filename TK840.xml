  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK840">
<l>kaḻāakkāl paḷḷiyuḷ vaittaṟṟāṟ cāṉṟōr</l>
<l>kuḻāattup pētai pukal</l>            
            </lg>
            <lg xml:lang="en">
<l>The appearance of a fool in an assembly of the learned is like placing (one's) unwashed feet on a bed.</l>
            </lg>
        </div>
