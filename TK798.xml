  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK798">
<l>uḷḷaṟka vuḷḷañ ciṟukuva koḷḷaṟka</l>
<l>vallaṟka ṇāṟṟaṟuppār naṭpu</l>            
            </lg>
            <lg xml:lang="en">
<l>Do not think of things that discourage your mind, nor contract friendship with those who would forsake you in adversity.</l>
            </lg>
        </div>
    </body>
