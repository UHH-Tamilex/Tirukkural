  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK558">
<l>iṉmaiyi ṉiṉṉā tuṭaimai muṟaiceyyā </l>
<l>maṉṉavaṉ kōlkīḻp paṭiṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>Property gives more sorrow than poverty, to those who live under the sceptre of a king without justice.</l>
            </lg>
        </div>
    </body>
