  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK356">
<l>kaṟṟīṇṭu meypporuḷ kaṇṭār talaippaṭuvar</l>
<l>maṟṟīṇṭu vārā neṟi</l>            
            </lg>
            <lg xml:lang="en">
<l>They, who in this birth have learned to know the True Being, enter the road which returns not into this world.</l>
            </lg>
        </div>
    </body>
