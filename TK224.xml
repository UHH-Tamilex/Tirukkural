  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK224">
<l>iṉṉā tirakkap paṭuta lirantava</l>
<l>ṉiṉmukaṅ kāṇu maḷavu</l>            
            </lg>
            <lg xml:lang="en">
<l>To see men begging from us in disagreeable, until we see their pleasant countenance.</l>
            </lg>
        </div>
