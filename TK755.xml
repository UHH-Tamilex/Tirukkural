  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK755">
<l>aruḷoṭu maṉpoṭum vārāp poruḷākkam</l>
<l>pullār puraḷa viṭal</l>            
            </lg>
            <lg xml:lang="en">
<l>(Kings) should rather avoid than seek the accumulation of wealth which does not flow in with mercy and love.</l>
            </lg>
        </div>
    </body>
