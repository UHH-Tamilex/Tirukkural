  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK522">
<l>viruppaṟāc cuṟṟa miyaiyi ṉaruppaṟā</l>
<l>vākkam palavun tarum</l>            
            </lg>
            <lg xml:lang="en">
<l>If (a man's) relatives remain attached to him with unchanging love, it will be a source of ever-increasing wealth.</l>
            </lg>
        </div>
