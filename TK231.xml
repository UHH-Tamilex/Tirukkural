  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK231">
<l>īta licaipaṭa vāḻta latuvalla</l>
<l>tūtiya millai yuyirkku</l>            
            </lg>
            <lg xml:lang="en">
<l>Give to the poor and live with praise. There is no greater profit to man than that.</l>
            </lg>
        </div>
