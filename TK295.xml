  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK295">
<l>maṉattoṭu vāymai moḻiyiṟ ṟavattoṭu</l>
<l>tāṉañcey vāriṉ talai</l>            
            </lg>
            <lg xml:lang="en">
<l>He, who speaks truth with all his heart, is superior to those who make gifts and practise austerities.</l>
            </lg>
