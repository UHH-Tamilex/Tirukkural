  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK620">
<l>ūḻaiyu muppakkaṅ kāṇpa rulaiviṉṟit </l>
<l> tāḻā tuñaṟṟu pavar</l>            
            </lg>
            <lg xml:lang="en">
<l>They who labour on, without fear and without fainting will see even fate (put) behind their back.</l>
            </lg>
        </div>
    </body>
