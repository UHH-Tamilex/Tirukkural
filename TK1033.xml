  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK1033">
<l>uḻutuṇṭu vāḻvārē vāḻvārmaṟ ṟellān </l>
<l>toḻutuṇṭu piṉcel pavar</l>            
            </lg>
            <lg xml:lang="en">
<l>They alone live who live by agriculture; all others lead a cringing, dependent life.</l>
            </lg>
        </div>
    </body>
