  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK621">
<l>iṭukkaṇ varuṅkā ṉakuka vataṉai </l>
<l> yaṭuttūrva taḵtoppa til</l>            
            </lg>
            <lg xml:lang="en">
<l>If troubles come, laugh; there is nothing like that, to press upon and drive away sorrow.</l>
            </lg>
