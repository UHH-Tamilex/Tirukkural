  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK1066">
<l>āviṟku nīreṉ ṟirappiṉu nāviṟ</l>
<l>kiravi ṉiḷivanta til</l>            
            </lg>
            <lg xml:lang="en">
<l>There is nothing more disgraceful to one's tongue than to use it in begging water even for a cow.</l>
            </lg>
        </div>
