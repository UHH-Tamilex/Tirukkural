  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK294">
<l>uḷḷattāṟ poyyā toḻuki ṉulakattā</l>
<l>ruḷḷattu ḷellā muḷaṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>He who, in his conduct, preserves a mind free from deceit, will dwell in the minds of all men.</l>
            </lg>
        </div>
