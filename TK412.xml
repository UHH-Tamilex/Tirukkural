  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK412">
<l>cevikkuṇa villāta pōḻtu ciṟitu</l>
<l>vayiṟṟukku mīyap paṭum</l>            
            </lg>
            <lg xml:lang="en">
<l>When there is no food for the ear, give a little also to the stomach.</l>
