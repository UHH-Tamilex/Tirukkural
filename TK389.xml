  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK389">
<l>cevikaippac coṟpoṟukkum paṇpuṭai vēntaṉ</l>
<l>kavikaikkīḻt taṅku mulaku</l>            
            </lg>
            <lg xml:lang="en">
<l>The whole world will dwell under the umbrella of the king, who can bear words that embitter the ear.</l>
