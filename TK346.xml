  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK346">
<l>yāṉeṉa teṉṉuñ cerukkaṟuppāṉ vāṉōrk</l>
<l>kuyarnta vulakam pukum</l>            
            </lg>
            <lg xml:lang="en">
<l>He who destroys the pride which says "I", "mine" will enter a world which is difficult even to the Gods to attain.</l>
            </lg>
        </div>
    </body>
