  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK1074">
<l>akappaṭṭi yāvāraik kāṇi ṉavariṉ</l>
<l>mikappaṭṭuc cemmākkuṅ kīḻ</l>            
            </lg>
            <lg xml:lang="en">
<l>The base feels proud when he sees persons whose acts meaner than his own.</l>
            </lg>
        </div>
    </body>
