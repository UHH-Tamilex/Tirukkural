  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK384">
<l>aṟaṉiḻukkā tallavai nīkki maṟaṉiḻukkā</l>
<l>māṉa muṭaiya taracu</l>            
            </lg>
            <lg xml:lang="en">
<l>He is a king who, with manly modesty, swerves not from virtue, and refrains from vice.</l>
            </lg>
        </div>
    </body>
