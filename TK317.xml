  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK317">
<l>eṉaittāṉu meññāṉṟum yārkku maṉattāṉu</l>
<l>māṇācey yāmai talai</l>            
            </lg>
            <lg xml:lang="en">
<l>It is the chief of all virtues not knowingly to do any person evil, even in the lowest degree, and at any time.</l>
            </lg>
        </div>
    </body>
