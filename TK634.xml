    <body>
        <div rend="parallel">
            <lg xml:id="TK634">
<l>teritalun tērntu ceyalu morutalaiyāc </l>
<l> collalum valla tamaiccu</l>            
            </lg>
            <lg xml:lang="en">
<l>The minister is one who is able to comprehend (the whole nature of an undertaking), execute it in the best manner possible, and offer assuring advice (in time of necessity).</l>
            </lg>
        </div>
