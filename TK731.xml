  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK731">
<l>taḷḷā viḷaiyuḷun takkārun tāḻvilāc</l>
<l>celvaruñ cērvatu nāṭu</l>            
            </lg>
            <lg xml:lang="en">
<l>A kingdom is that in which (those who carry on) a complete cultivation, virtuous persons, and merchants with inexhaustible wealth, dwell together.</l>
            </lg>
        </div>
    </body>
