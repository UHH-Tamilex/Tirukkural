  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK628">
<l>iṉpam viḻaiyā tiṭumpaiyiyalpeṉpāṉ </l>
<l> ṟuṉpa muṟuta lilaṉ</l>            
            </lg>
            <lg xml:lang="en">
<l>That man never experiences sorrow, who does not seek for pleasure, and who considers distress to be natural (to man).</l>
            </lg>
        </div>
    </body>
