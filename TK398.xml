  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK398">
<l>orumaikkaṭ ṭāṉkaṟṟa kalvi yoruvaṟ</l>
<l> keḻumaiyu mēmāp puṭaittu</l>            
            </lg>
            <lg xml:lang="en">
<l>The learning, which a man has acquired in one birth, will yield him pleasure during seven births.</l>
            </lg>
        </div>
