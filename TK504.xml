  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK504">
<l>kuṇanāṭik kuṟṟamu nāṭi yavaṟṟuṇ</l>
<l>mikaināṭi mikka koḷal</l>            
            </lg>
            <lg xml:lang="en">
<l>Let (a king) consider (a man's) good qualities, as well as his faults, and then judge (of his character) by that which prevails.</l>
            </lg>
        </div>
    </body>
