  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK454">
<l>maṉattu ḷatupōlak kāṭṭi yoruvaṟ</l>
<l>kiṉattuḷa tāku maṟivu</l>            
            </lg>
            <lg xml:lang="en">
<l>Wisdom appears to rest in the mind, but it really exists to a man in his companions.</l>
            </lg>
        </div>
