  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK337">
<l>orupoḻutum vāḻva taṟiyār karutupa</l>
<l>kōṭiyu malla pala</l>            
            </lg>
            <lg xml:lang="en">
<l>Innumerable are the thoughts which occupy the mind of (the unwise), who know not that they shall live another moment.</l>
            </lg>
        </div>
