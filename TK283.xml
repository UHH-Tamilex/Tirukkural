  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK283">
<l>kaḷaviṉā lākiya vākka maḷaviṟan</l>
<l>tāvatu pōlak keṭum</l>            
            </lg>
            <lg xml:lang="en">
<l>The property, which is acquired by fraud, will entirely perish, even while it seems to increase.</l>
            </lg>
        </div>
