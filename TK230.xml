  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK230">
<l>cātali ṉiṉṉāta tillai yiṉitatūu</l>
<l>mīta liyaiyāk kaṭai</l>            
            </lg>
            <lg xml:lang="en">
<l>Nothing is more unpleasant than death: yet even that is pleasant where charity cannot be exercised.</l>
            </lg>
        </div>
    </body>
