  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK810">
<l>viḻaiyār viḻaiyap paṭuvar paḻaiyārkaṭ</l>
<l>paṇpiṉ ṟalaippiriyā tār</l>            
            </lg>
            <lg xml:lang="en">
<l>Even enemies will love those who have never changed in their affection to their long-standingfriends.</l>
            </lg>
