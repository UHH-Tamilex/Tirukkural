  <text xml:lang="ta" type="edition">
    <body>
        <div rend="parallel">
            <lg xml:id="TK213">
<l>puttē ḷulakattu mīṇṭum peṟaṟkaritē</l>
<l>yoppuravi ṉalla piṟa</l>            
            </lg>
            <lg xml:lang="en">
<l>It is difficult to obtain another good equal to benevolence either in this world or in that of the gods.</l>
            </lg>
        </div>
    </body>
